{
  "name": "fmz-dashboard",
  "private": true,
"version": "1.1.0",
  "fmzReleaseLabel": "v1.1",
  "fmzFeatures": {
    "sanguo": true,
    "baobao": true,
"audio": true,
    "battle": false,
    "treasury": false,
    "preliminary": false,
    "users": false,
"quota": "local"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "node scripts/dev-all.mjs",
    "build": "vite build",
    "reactions-server": "npm run start --prefix server",
    "defense-tower-server": "node server/defense-tower-server.mjs",
    "audio-server": "node server/audio-extractor-server.mjs",
    "quota-server": "node server/quota-server.cjs",
    "check:reactions": "node scripts/check-reactions.mjs",
    "pack": "node scripts/bump-patch.mjs && vite build && node scripts/pack-release.mjs",
    "pack:quota": "node scripts/pack-quota.mjs",
    "preview": "vite preview",
    "preview:public": "vite preview --host 0.0.0.0 --port 4173",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "@playwright/test": "^1.51.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "~5.7.2",
    "vite": "^6.0.3"
  }
}
