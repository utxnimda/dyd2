{
  "name": "fmz-dashboard",
  "private": true,
  "version": "0.5.0",
  "fmzReleaseLabel": "v0.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -n reactions,vite -c cyan,magenta \"npm run reactions-server\" \"npm run dev\"",
    "build": "vite build",
    "reactions-server": "npm run start --prefix server",
    "check:reactions": "node scripts/check-reactions.mjs",
    "pack": "vite build && node scripts/pack-release.mjs",
    "preview": "vite preview",
    "preview:public": "vite preview --host 0.0.0.0 --port 4173",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "@playwright/test": "^1.51.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "~5.7.2",
    "vite": "^6.0.3"
  }
}
